digraph kokin {
  graph [
    rankdir=LR
    fontname="Helvetica"
    splines=polyline
    nodesep=0.4
    ranksep=1.4
    bgcolor="#faf9f7"
    newrank=true
  ]
  node [
    fontname="Helvetica"
    fontsize=10
    shape=plain
  ]
  edge [
    fontname="Helvetica"
    fontsize=8
    color="#888888"
    penwidth=0.9
  ]

  /* ════════════════════════════════
     BODY
     ════════════════════════════════ */
  subgraph cluster_body {
    label="<body>"
    style="filled,rounded"
    fillcolor="#eef4fb"
    color="#7aaad0"
    fontname="Helvetica"
    fontsize=12

    b_div [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;div&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">type: 部立</TD></TR>
      <TR><TD ALIGN="LEFT">head: 春哥上</TD></TR>
    </TABLE>>]

    b_note_d [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;note&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">type: 詞書</TD></TR>
      <TR><TD ALIGN="LEFT">target: #n1</TD></TR>
      <TR><TD ALIGN="LEFT">ふるとしに[app]たちける[app]よめる</TD></TR>
    </TABLE>>]

    b_app [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;app&gt;</B></TD></TR>
    </TABLE>>]

    b_lem [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;lem&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">wit: #国</TD></TR>
      <TR><TD ALIGN="LEFT">春</TD></TR>
    </TABLE>>]

    b_rdg [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;rdg&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">wit: #前</TD></TR>
      <TR><TD ALIGN="LEFT">春の</TD></TR>
    </TABLE>>]

    b_note_a [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;note&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">type: 作者名</TD></TR>
    </TABLE>>]

    b_persname [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;persName&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">type: 作者</TD></TR>
      <TR><TD ALIGN="LEFT">corresp: #在原元方</TD></TR>
      <TR><TD ALIGN="LEFT">在原元方</TD></TR>
    </TABLE>>]

    b_l [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;l&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">n: 1</TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: n1</TD></TR>
      <TR><TD ALIGN="LEFT">resp: #在原元方</TD></TR>
    </TABLE>>]

    b_seg1 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;seg&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">年の内に</TD></TR>
    </TABLE>>]

    b_w_toshi [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;w&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">年</TD></TR>
      <TR><TD ALIGN="LEFT">lemmaRef: #とし.年</TD></TR>
    </TABLE>>]

    b_w_no [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;w&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">の</TD></TR>
      <TR><TD ALIGN="LEFT">lemmaRef: #の.の</TD></TR>
    </TABLE>>]

    b_seg2 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;seg&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">春はきにけり</TD></TR>
    </TABLE>>]

    b_w_haru [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;w&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">春</TD></TR>
      <TR><TD ALIGN="LEFT">lemmaRef: #はる.春</TD></TR>
    </TABLE>>]

    b_w_ha [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;w&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">は</TD></TR>
      <TR><TD ALIGN="LEFT">lemmaRef: #は.は</TD></TR>
    </TABLE>>]

    b_phr [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;phr&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: kana1-1</TD></TR>
      <TR><TD ALIGN="LEFT">やまとうたは人のこゝろを…</TD></TR>
    </TABLE>>]

    b_pb [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;pb&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">n: 1-1r</TD></TR>
      <TR><TD ALIGN="LEFT">facs: #p001</TD></TR>
    </TABLE>>]

    b_div    -> b_note_d   [style=dashed]
    b_div    -> b_note_a   [style=dashed]
    b_div    -> b_l        [xlabel="contains" style=dashed]
    b_div    -> b_phr      [style=dashed]
    b_div    -> b_pb       [style=dashed]
    b_note_d -> b_app      [style=dashed]
    b_note_d -> b_l        [xlabel="target" color="#448899"]
    b_note_a -> b_persname [style=dashed]
    b_app    -> b_lem      [style=dashed]
    b_app    -> b_rdg      [style=dashed]
    b_l      -> b_seg1     [style=dashed]
    b_l      -> b_seg2     [style=dashed]
    b_seg1   -> b_w_toshi  [style=dashed]
    b_seg1   -> b_w_no     [style=dashed]
    b_seg2   -> b_w_haru   [style=dashed]
    b_seg2   -> b_w_ha     [style=dashed]
  }

  /* ════════════════════════════════
     BACK (single box)
     ════════════════════════════════ */
  subgraph cluster_back {
    label="<back>"
    style="filled,rounded"
    fillcolor="#f5f5f0"
    color="#888877"
    fontname="Helvetica"
    fontsize=12

    subgraph cluster_ri {
      label="reading-index"
      style="filled,rounded"
      fillcolor="#f0f7ee"
      color="#88bb77"
      fontname="Helvetica"
      fontsize=10

      ri_entry [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
        <TR><TD BGCOLOR="#88bb77"><B>&lt;entry&gt;</B></TD></TR>
        <TR><TD ALIGN="LEFT">xml:id: はる</TD></TR>
      </TABLE>>]

      hom_haru [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
        <TR><TD BGCOLOR="#88bb77"><B>&lt;hom&gt;</B></TD></TR>
        <TR><TD ALIGN="LEFT">xml:id: はる.春</TD></TR>
        <TR><TD ALIGN="LEFT">ref: #春</TD></TR>
      </TABLE>>]

      hom_haru2 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
        <TR><TD BGCOLOR="#88bb77"><B>&lt;hom&gt;</B></TD></TR>
        <TR><TD ALIGN="LEFT">xml:id: はる.張る</TD></TR>
        <TR><TD ALIGN="LEFT">ref: #張る</TD></TR>
      </TABLE>>]

      ri_entry -> hom_haru  [style=dashed]
      ri_entry -> hom_haru2 [style=dashed]
    }

    subgraph cluster_dict {
      label="dictionary"
      style="filled,rounded"
      fillcolor="#fef9ec"
      color="#ccaa44"
      fontname="Helvetica"
      fontsize=10

      e_haru [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
        <TR><TD BGCOLOR="#ccaa44"><B>&lt;entry&gt;</B></TD></TR>
        <TR><TD ALIGN="LEFT">xml:id: 春</TD></TR>
        <TR><TD ALIGN="LEFT">pos: N.g</TD></TR>
        <TR><TD BGCOLOR="#e8cc88" ALIGN="LEFT"><B>&lt;sense&gt;</B> ana: #WLSPH.1.1624</TD></TR>
      </TABLE>>]

      e_aki [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
        <TR><TD BGCOLOR="#ccaa44"><B>&lt;entry&gt;</B></TD></TR>
        <TR><TD ALIGN="LEFT">xml:id: 秋</TD></TR>
        <TR><TD ALIGN="LEFT">pos: N.g</TD></TR>
        <TR><TD BGCOLOR="#e8cc88" ALIGN="LEFT"><B>&lt;sense&gt;</B> ana: #WLSPH.1.1624</TD></TR>
      </TABLE>>]

      e_natsu [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
        <TR><TD BGCOLOR="#ccaa44"><B>&lt;entry&gt;</B></TD></TR>
        <TR><TD ALIGN="LEFT">xml:id: 夏</TD></TR>
        <TR><TD ALIGN="LEFT">pos: N.g</TD></TR>
        <TR><TD BGCOLOR="#e8cc88" ALIGN="LEFT"><B>&lt;sense&gt;</B> ana: #WLSPH.1.1624</TD></TR>
      </TABLE>>]

      e_fuyu [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
        <TR><TD BGCOLOR="#ccaa44"><B>&lt;entry&gt;</B></TD></TR>
        <TR><TD ALIGN="LEFT">xml:id: 冬</TD></TR>
        <TR><TD ALIGN="LEFT">pos: N.g</TD></TR>
        <TR><TD BGCOLOR="#e8cc88" ALIGN="LEFT"><B>&lt;sense&gt;</B> ana: #WLSPH.1.1624</TD></TR>
      </TABLE>>]

      e_comp [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
        <TR><TD BGCOLOR="#ccaa44"><B>&lt;entry&gt;</B></TD></TR>
        <TR><TD ALIGN="LEFT">xml:id: 春霞</TD></TR>
        <TR><TD ALIGN="LEFT">type: compound</TD></TR>
      </TABLE>>]

      e_comp  -> e_haru  [xlabel="component" style=dashed color="#997722"]
    }

    subgraph cluster_cls {
      label="classification"
      style="filled,rounded"
      fillcolor="#fdf0f0"
      color="#cc8888"
      fontname="Helvetica"
      fontsize=10

      wlsph [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
        <TR><TD BGCOLOR="#cc8888"><B>&lt;item&gt;</B></TD></TR>
        <TR><TD ALIGN="LEFT">xml:id: WLSPH.1.1624</TD></TR>
        <TR><TD ALIGN="LEFT">desc: 体-抽象的関係-位置・地点・場合-季節</TD></TR>
        <TR><TD ALIGN="LEFT"><I>八代集版</I></TD></TR>
      </TABLE>>]

      wlsp [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
        <TR><TD BGCOLOR="#e8b0b0"><B>&lt;item&gt;</B></TD></TR>
        <TR><TD ALIGN="LEFT">xml:id: WLSP.1.1624</TD></TR>
        <TR><TD ALIGN="LEFT">desc: 体-関係-時間-季節</TD></TR>
        <TR><TD ALIGN="LEFT"><I>現代語版</I></TD></TR>
      </TABLE>>]
    }

    subgraph cluster_person {
      label="listPerson"
      style="filled,rounded"
      fillcolor="#f5f0fb"
      color="#9977cc"
      fontname="Helvetica"
      fontsize=10

      person [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
        <TR><TD BGCOLOR="#9977cc"><B>&lt;person&gt;</B></TD></TR>
        <TR><TD ALIGN="LEFT">xml:id: 在原元方</TD></TR>
        <TR><TD ALIGN="LEFT">sex: 1</TD></TR>
        <TR><TD ALIGN="LEFT">persName: ありわらの／もとかた</TD></TR>
        <TR><TD ALIGN="LEFT">birth: 不明</TD></TR>
        <TR><TD ALIGN="LEFT">death: 不明</TD></TR>
        <TR><TD ALIGN="LEFT">idno[VIAF]: viaf/114305486</TD></TR>
        <TR><TD ALIGN="LEFT">idno[国書DB]: 588363</TD></TR>
      </TABLE>>]
    }

    subgraph cluster_facs {
      label="facsimile"
      style="filled,rounded"
      fillcolor="#f7f0ea"
      color="#bb9966"
      fontname="Helvetica"
      fontsize=10

      surface [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
        <TR><TD BGCOLOR="#bb9966"><B>&lt;surface&gt;</B></TD></TR>
        <TR><TD ALIGN="LEFT">xml:id: p001</TD></TR>
      </TABLE>>]
    }
  }

  /* ── back sub-cluster ordering (invisible chain between visible nodes) ── */
  ri_entry -> e_haru -> wlsph -> person -> surface [style=invis weight=10]

  /* ════════════════════════════════
     CROSS-CLUSTER EDGES
     ════════════════════════════════ */

  b_w_haru   -> hom_haru [xlabel="lemmaRef" style=bold color="#4477bb"]
  hom_haru   -> e_haru   [xlabel="ref"      color="#448844"]
  e_haru     -> wlsph    [xlabel="sense/ana" style=bold color="#bb6633"]
  e_aki      -> wlsph    [style=bold color="#bb6633"]
  e_natsu    -> wlsph    [style=bold color="#bb6633"]
  e_fuyu     -> wlsph    [style=bold color="#bb6633"]
  e_haru     -> wlsp     [color="#cc9999" style=dashed]
  b_persname -> person   [xlabel="corresp"  color="#7755aa"]
  b_l        -> person   [xlabel="resp"     color="#7755aa"]
  b_pb       -> surface  [xlabel="facs"     color="#996644"]
}
