digraph search_uguisu {
  graph [
    rankdir=LR
    fontname="Helvetica"
    bgcolor="#faf9f7"
    splines=polyline
    nodesep=0.5
    ranksep=1.2
    newrank=true
  ]
  node [fontname="Helvetica" fontsize=10 shape=plain]
  edge [fontname="Helvetica" fontsize=8 color="#aaaaaa" penwidth=0.8]

  /* ── query input ── */
  query [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#fff8e8" COLOR="#cc8800">
    <TR><TD><B>クエリ</B></TD></TR>
    <TR><TD>うぐひす</TD></TR>
  </TABLE>>]

  /* ── reading-index ── */
  subgraph cluster_ri {
    label="reading-index"
    style="filled,rounded"
    fillcolor="#f0f7ee"
    color="#88bb77"
    fontname="Helvetica"
    fontsize=10

    ri_e [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#88bb77"><B>&lt;entry&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: うぐひす</TD></TR>
    </TABLE>>]

    hom1 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#88bb77"><B>&lt;hom&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: うぐひす.鴬</TD></TR>
    </TABLE>>]

    ri_e -> hom1 [style=dashed color="#88bb77"]
  }

  /* ── dictionary ── */
  subgraph cluster_dict {
    label="dictionary"
    style="filled,rounded"
    fillcolor="#fef9ec"
    color="#ccaa44"
    fontname="Helvetica"
    fontsize=10

    e1 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#ccaa44"><B>&lt;entry&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: 鴬</TD></TR>
      <TR><TD BGCOLOR="#e8cc88" ALIGN="LEFT"><B>&lt;sense&gt;</B> ana: #WLSPH.1.5620</TD></TR>
    </TABLE>>]

    e2 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#ccaa44"><B>&lt;entry&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: 鶯</TD></TR>
      <TR><TD BGCOLOR="#e8cc88" ALIGN="LEFT"><B>&lt;sense&gt;</B> ana: #WLSPH.1.5620</TD></TR>
    </TABLE>>]

    e3 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#ccaa44"><B>&lt;entry&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: ほととぎす</TD></TR>
      <TR><TD BGCOLOR="#e8cc88" ALIGN="LEFT"><B>&lt;sense&gt;</B> ana: #WLSPH.1.5620</TD></TR>
    </TABLE>>]
  }

  /* ── classification ── */
  subgraph cluster_cls {
    label="classification"
    style="filled,rounded"
    fillcolor="#fdf0f0"
    color="#cc8888"
    fontname="Helvetica"
    fontsize=10

    wlsph [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#cc8888"><B>&lt;item&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: WLSPH.1.5620</TD></TR>
      <TR><TD ALIGN="LEFT">desc: 体-…-動物-鳥</TD></TR>
    </TABLE>>]
  }

  /* ── body ── */
  subgraph cluster_body {
    label="&lt;body&gt;"
    style="filled,rounded"
    fillcolor="#eef4fb"
    color="#7aaad0"
    fontname="Helvetica"
    fontsize=10

    w1 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;w&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">うぐひす</TD></TR>
      <TR><TD ALIGN="LEFT">lemmaRef: #うぐひす.鴬</TD></TR>
    </TABLE>>]

    w2 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;w&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">ほととぎす</TD></TR>
      <TR><TD ALIGN="LEFT">lemmaRef: #ほととぎす.ほととぎす</TD></TR>
    </TABLE>>]
  }

  /* ── search path (highlighted) ── */
  query -> ri_e    [style=bold penwidth=2 color="#cc6600"]
  hom1  -> e1      [xlabel="ref"      style=bold penwidth=2 color="#cc6600"]
  e1    -> wlsph   [xlabel="sense/ana" style=bold penwidth=2 color="#cc6600"]
  e2    -> wlsph   [style=bold penwidth=1.5 color="#cc6600"]
  e3    -> wlsph   [style=bold penwidth=1.5 color="#cc6600"]
  w1    -> hom1    [xlabel="lemmaRef" style=bold penwidth=2 color="#4477bb" dir=back]
  w2    -> e3      [xlabel="lemmaRef" style=bold penwidth=1.5 color="#4477bb" dir=back]
}
