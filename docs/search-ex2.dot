digraph search_aki {
  graph [
    rankdir=LR
    fontname="Helvetica"
    bgcolor="#faf9f7"
    splines=polyline
    nodesep=0.5
    ranksep=1.2
    newrank=true
  ]
  node [fontname="Helvetica" fontsize=10 shape=plain]
  edge [fontname="Helvetica" fontsize=8 color="#aaaaaa" penwidth=0.8]

  /* ── query input ── */
  query [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#fff8e8" COLOR="#cc8800">
    <TR><TD><B>クエリ</B></TD></TR>
    <TR><TD>あき</TD></TR>
  </TABLE>>]

  /* ── reading-index ── */
  subgraph cluster_ri {
    label="reading-index"
    style="filled,rounded"
    fillcolor="#f0f7ee"
    color="#88bb77"
    fontname="Helvetica"
    fontsize=10

    ri_aki [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#88bb77"><B>&lt;entry&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: あき</TD></TR>
    </TABLE>>]

    hom_aki_aki [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#88bb77"><B>&lt;hom&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: あき.秋</TD></TR>
    </TABLE>>]

    hom_aki_aku [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#88bb77"><B>&lt;hom&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: あき.飽く</TD></TR>
    </TABLE>>]

    ri_aka [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#88bb77"><B>&lt;entry&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: あか</TD></TR>
    </TABLE>>]

    hom_aka_aku [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#88bb77"><B>&lt;hom&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: あか.飽く</TD></TR>
    </TABLE>>]

    ri_aki  -> hom_aki_aki [style=dashed color="#88bb77"]
    ri_aki  -> hom_aki_aku [style=dashed color="#88bb77"]
    ri_aka  -> hom_aka_aku [style=dashed color="#88bb77"]
  }

  /* ── dictionary ── */
  subgraph cluster_dict {
    label="dictionary"
    style="filled,rounded"
    fillcolor="#fef9ec"
    color="#ccaa44"
    fontname="Helvetica"
    fontsize=10

    e_aki [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#ccaa44"><B>&lt;entry&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: 秋</TD></TR>
      <TR><TD ALIGN="LEFT">pos: N.g</TD></TR>
    </TABLE>>]

    e_aku [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#ccaa44"><B>&lt;entry&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: 飽く</TD></TR>
      <TR><TD ALIGN="LEFT">pos: V.k</TD></TR>
    </TABLE>>]
  }

  /* ── body ── */
  subgraph cluster_body {
    label="&lt;body&gt;"
    style="filled,rounded"
    fillcolor="#eef4fb"
    color="#7aaad0"
    fontname="Helvetica"
    fontsize=10

    l1 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;l&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">n: 169</TD></TR>
    </TABLE>>]

    w1 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;w&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">秋</TD></TR>
      <TR><TD ALIGN="LEFT">lemmaRef: #あき.秋</TD></TR>
    </TABLE>>]

    l2 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;l&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">n: 742</TD></TR>
    </TABLE>>]

    w2 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;w&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">あか</TD></TR>
      <TR><TD ALIGN="LEFT">lemmaRef: #あか.飽く</TD></TR>
    </TABLE>>]

    l3 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;l&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">n: 581</TD></TR>
    </TABLE>>]

    w3 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;w&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">秋</TD></TR>
      <TR><TD ALIGN="LEFT">lemmaRef: #あき.飽く</TD></TR>
    </TABLE>>]

    l1 -> w1 [style=dashed color="#7aaad0"]
    l2 -> w2 [style=dashed color="#7aaad0"]
    l3 -> w3 [style=dashed color="#7aaad0"]
  }

  /* ── search path (highlighted) ── */
  query       -> ri_aki      [style=bold penwidth=2 color="#cc6600"]
  hom_aki_aki -> e_aki       [xlabel="ref" style=bold penwidth=2 color="#cc6600"]
  hom_aki_aku -> e_aku       [xlabel="ref" style=bold penwidth=2 color="#cc6600"]
  hom_aka_aku -> e_aku       [xlabel="ref" penwidth=1.2 color="#999999"]
  w1          -> hom_aki_aki [xlabel="lemmaRef" style=bold penwidth=2 color="#4477bb" dir=back]
  w2          -> hom_aka_aku [xlabel="lemmaRef" style=bold penwidth=2 color="#4477bb" dir=back]
  w3          -> hom_aki_aku [xlabel="lemmaRef" style=bold penwidth=2 color="#4477bb" dir=back]
}
