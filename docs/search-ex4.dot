digraph search_kanazukai {
  graph [
    rankdir=LR
    fontname="Helvetica"
    bgcolor="#faf9f7"
    splines=polyline
    nodesep=0.5
    ranksep=1.2
    newrank=true
  ]
  node [fontname="Helvetica" fontsize=10 shape=plain]
  edge [fontname="Helvetica" fontsize=8 color="#aaaaaa" penwidth=0.8]

  /* ── query: おぐら (modern kana) ── */
  query [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#fff8e8" COLOR="#cc8800">
    <TR><TD><B>クエリ</B></TD></TR>
    <TR><TD>おぐら</TD></TR>
  </TABLE>>]

  /* ── reading-index ── */
  subgraph cluster_ri {
    label="reading-index"
    style="filled,rounded"
    fillcolor="#f0f7ee"
    color="#88bb77"
    fontname="Helvetica"
    fontsize=10

    ri_o [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#88bb77"><B>&lt;entry&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: おぐら</TD></TR>
    </TABLE>>]

    hom_o [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#88bb77"><B>&lt;hom&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: おぐら.小倉</TD></TR>
    </TABLE>>]

    ri_wo [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#88bb77"><B>&lt;entry&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: をぐら</TD></TR>
    </TABLE>>]

    hom_wo [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#88bb77"><B>&lt;hom&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: をぐら.小倉</TD></TR>
    </TABLE>>]

    ri_o  -> hom_o  [style=dashed color="#88bb77"]
    ri_wo -> hom_wo [style=dashed color="#88bb77"]
  }

  /* ── dictionary ── */
  subgraph cluster_dict {
    label="dictionary"
    style="filled,rounded"
    fillcolor="#fef9ec"
    color="#ccaa44"
    fontname="Helvetica"
    fontsize=10

    e_ogura [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#ccaa44"><B>&lt;entry&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">xml:id: 小倉</TD></TR>
      <TR><TD ALIGN="LEFT">pos: N.p</TD></TR>
    </TABLE>>]
  }

  /* ── body ── */
  subgraph cluster_body {
    label="&lt;body&gt;"
    style="filled,rounded"
    fillcolor="#eef4fb"
    color="#7aaad0"
    fontname="Helvetica"
    fontsize=10

    l1 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;l&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">n: 312</TD></TR>
    </TABLE>>]

    w1 [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD BGCOLOR="#7aaad0"><B>&lt;w&gt;</B></TD></TR>
      <TR><TD ALIGN="LEFT">をくら</TD></TR>
      <TR><TD ALIGN="LEFT">lemmaRef: #をぐら.小倉</TD></TR>
    </TABLE>>]

    l1 -> w1 [style=dashed color="#7aaad0"]
  }

  /* ── search path ── */
  query   -> ri_o   [style=bold penwidth=2 color="#cc6600"]
  hom_o   -> e_ogura [xlabel="ref" style=bold penwidth=2 color="#cc6600"]
  hom_wo  -> e_ogura [xlabel="ref" style=bold penwidth=1.5 color="#cc6600"]
  w1      -> hom_wo  [xlabel="lemmaRef" style=bold penwidth=2 color="#4477bb" dir=back]
}
